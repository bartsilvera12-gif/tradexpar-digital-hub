# API de pagos (Node en Hostinger u otro). Copiar a `.env` en el servidor; no commitear secretos.

PORT=8787
# Misma clave que el front envía en `x-api-key` (VITE_API_KEY)
API_PUBLIC_KEY=

# Host o URL completa (si no tiene esquema, se usa https://)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Schema donde está la tabla `orders` (expuesto en PostgREST). Si queda en `public` por error, la API fuerza `tradexpar`.
SUPABASE_SCHEMA=tradexpar
# Opcional: solo para esta API de pagos (tiene prioridad sobre SUPABASE_SCHEMA).
# SUPABASE_ORDERS_SCHEMA=tradexpar

# PagoPar acepta *_KEY o *_TOKEN (mismo valor que en el panel)
PAGOPAR_PUBLIC_KEY=
PAGOPAR_PRIVATE_KEY=
# PAGOPAR_PUBLIC_TOKEN=
# PAGOPAR_PRIVATE_TOKEN=
# Opcionales (defaults en código)
PAGOPAR_FORMA_PAGO=9
PAGOPAR_ITEM_CATEGORIA=909
PAGOPAR_ITEM_CIUDAD=1
PAGOPAR_ITEM_PRODUCTO_ID=895
PAGOPAR_ITEM_IMAGEN_URL=https://www.pagopar.com/static/img/logo.png

PAGOPAR_RETURN_URL=https://greenyellow-goat-534491.hostingersite.com/success?hash=($hash)
PAGOPAR_WEBHOOK_URL=https://greenyellow-goat-534491.hostingersite.com/api/pagopar/webhook

# Solo desarrollo: true desactiva verificación SHA1 del token del webhook
# PAGOPAR_SKIP_WEBHOOK_VERIFY=true

# =============================================================================
# API de pagos (Node). Copiar a `.env` en el servidor; no commitear secretos.
# =============================================================================

PORT=8787
# Mismo valor que VITE_API_KEY en la raíz (cliente) para el header x-api-key.
API_PUBLIC_KEY=neura123

# -----------------------------------------------------------------------------
# Supabase (pedidos)
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Misma anon key que el frontend (validar JWT admin en /api/admin/dropi/*).
# En local: si cargás `.env` en la raíz del repo con VITE_SUPABASE_ANON_KEY, el server la usa como fallback.
SUPABASE_ANON_KEY=
SUPABASE_SCHEMA=tradexpar
# SUPABASE_ORDERS_SCHEMA=tradexpar
# SUPABASE_LOG_DEBUG=0

# -----------------------------------------------------------------------------
# PagoPar — credenciales (usar *_KEY; *_TOKEN solo compat, ver warnings si ambos)
# -----------------------------------------------------------------------------
PAGOPAR_PUBLIC_KEY=
PAGOPAR_PRIVATE_KEY=
# PAGOPAR_PUBLIC_TOKEN=
# PAGOPAR_PRIVATE_TOKEN=

# Entorno: production (default) | staging
PAGOPAR_ENV=production
# Staging con URLs propias (las que indique soporte):
# PAGOPAR_API_BASE_URL=
# PAGOPAR_CHECKOUT_BASE_URL=
# PAGOPAR_STAGING_USE_OFFICIAL_HOSTS=1

# Body iniciar-transacción: plano (oficial). Wrapper PHP solo si =1
PAGOPAR_ORDER_WRAPPER=0

# Incluir url_respuesta / url_notificacion en el JSON (default off; panel suele tenerlas)
# PAGOPAR_SEND_PAYLOAD_URLS=1
PAGOPAR_RETURN_URL=https://greenyellow-goat-534491.hostingersite.com/success?hash=${hash}
PAGOPAR_WEBHOOK_URL=https://greenyellow-goat-534491.hostingersite.com/api/pagopar/webhook

PAGOPAR_FORMA_PAGO=9

# Modo ítem PagoPar: physical (default tienda) | virtual — afecta categoria/ciudad ítem/descripcion/vendedor_* por env
# PAGOPAR_PRODUCT_MODE=physical
# Si =1 y modo physical: exige customer_address + customer_city_code en orders
# PAGOPAR_PHYSICAL_REQUIRE_BUYER_SHIPPING=0

# Compartidas (fallback si no hay *_PHYSICAL / *_VIRTUAL)
PAGOPAR_ITEM_CATEGORIA=909
PAGOPAR_ITEM_CIUDAD=1
PAGOPAR_ITEM_PRODUCTO_ID=895
PAGOPAR_ITEM_IMAGEN_URL=https://www.pagopar.com/static/img/logo.png
# PAGOPAR_ITEM_DESCRIPCION=
# Overrides por modo (IDs de categoría/producto según panel PagoPar / soporte)
# PAGOPAR_ITEM_CATEGORIA_PHYSICAL=
# PAGOPAR_ITEM_CATEGORIA_VIRTUAL=
# PAGOPAR_ITEM_CIUDAD_PHYSICAL=
# PAGOPAR_ITEM_CIUDAD_VIRTUAL=
# PAGOPAR_ITEM_PRODUCTO_ID_PHYSICAL=
# PAGOPAR_ITEM_PRODUCTO_ID_VIRTUAL=
# Placeholders en texto: {order_short} {order_id}
# PAGOPAR_ITEM_DESCRIPCION_PHYSICAL=
# PAGOPAR_ITEM_DESCRIPCION_VIRTUAL=
# PAGOPAR_DESCRIPCION_RESUMEN_PHYSICAL=
# PAGOPAR_DESCRIPCION_RESUMEN_VIRTUAL=
# PAGOPAR_VENDEDOR_TELEFONO=
# PAGOPAR_VENDEDOR_DIRECCION=
# PAGOPAR_VENDEDOR_DIRECCION_REFERENCIA=
# PAGOPAR_VENDEDOR_DIRECCION_COORDENADAS=
# PAGOPAR_VENDEDOR_TELEFONO_PHYSICAL=
# PAGOPAR_VENDEDOR_TELEFONO_VIRTUAL=
# PAGOPAR_VENDEDOR_DIRECCION_PHYSICAL=
# PAGOPAR_VENDEDOR_DIRECCION_VIRTUAL=
# PAGOPAR_VENDEDOR_DIRECCION_REFERENCIA_PHYSICAL=
# PAGOPAR_VENDEDOR_DIRECCION_REFERENCIA_VIRTUAL=
# PAGOPAR_VENDEDOR_DIRECCION_COORDENADAS_PHYSICAL=
# PAGOPAR_VENDEDOR_DIRECCION_COORDENADAS_VIRTUAL=
# PAGOPAR_COMPRADOR_CIUDAD=1

# Logs VPS / depuración token (activar explícitamente con =1)
# PAGOPAR_LOG_INICIAR_TRANSACCION=1
# PAGOPAR_LOG_TOKEN_DEBUG=1
# PAGOPAR_LOG_SHA1_PLAINTEXT=1
# PAGOPAR_LOG_ENDPOINTS=0

# Solo desarrollo
# PAGOPAR_SKIP_WEBHOOK_VERIFY=true

# -----------------------------------------------------------------------------
# Dropi (catálogo → tradexpar.products; rutas POST/GET /api/admin/dropi/*)
# -----------------------------------------------------------------------------
# Bridge HTTP en WordPress/Hostinger (listado/detalle sin llamar api.dropi.* desde el VPS).
# Sin barra final. Ej.: https://tienda.tradexpar.com.py/wp-json/tradexpar-dropi/v1
# Node: GET {url}/products · GET {url}/product/{id} · header x-bridge-key
# POST {url}/{DROPI_BRIDGE_ORDER_PATH} — crear pedido en Dropi tras webhook Pagopar (default: order)
DROPI_BRIDGE_URL=
DROPI_BRIDGE_KEY=
# Mín. guaraníes sumados a base de producto en el tercer término: max(venta, sugerida, base+margen) > costo Dropi
# DROPI_MIN_MARGIN_PYG=5000
# DROPI_MIN_MARGIN=5000
# DROPI_BRIDGE_ORDER_PATH=order
# Si el bridge devuelve paths relativos en url / photos[].url (plugin: IMG_URL + url):
# DROPI_BRIDGE_IMG_URL=https://…
# Si urlS3 es path bajo CloudFront/CDN (plugin: CDN + urlS3):
# DROPI_BRIDGE_CDN_URL=https://…
# DROPI_BRIDGE_DEBUG=1       # respuesta JSON resumida en logs [dropi/bridge]
# Bucket storage (tras ejecutar SQL ARRAY 1 en supabase/tradexpar_dropi_supabase_arrays.sql)
DROPI_STORAGE_BUCKET=catalog-images
# DROPI_REQUIRE_SUPER=false   # igual patrón que FASTRAX_REQUIRE_SUPER: false solo en dev
# DROPI_LIST_DEBUG=1         # logs extra en sync-products (parsed.objects)
